MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=unievent
MYSQL_USER=unievent_app
MYSQL_PASSWORD=

SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/unievent?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

FACEBOOK_ENABLED=true
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8080/api/facebook/callback
FACEBOOK_GRAPH_VERSION=v25.0
FRONTEND_URL=http://localhost

UNIEVENT_SECURITY_JWT_SECRET=dev-secret-key-must-be-at-least-256-bits-in-production
UNIEVENT_SECURITY_JWT_EXPIRATION_MS=86400000
UNIEVENT_SECURITY_JWT_REFRESH_SECRET=dev-refresh-secret-key-must-be-at-least-256-bits-in-production
UNIEVENT_SECURITY_JWT_REFRESH_EXPIRATION_MS=604800000

VAULT_TOKEN=
VAULT_UNSEAL_TOKEN=
VAULT_ROOT_TOKEN=

ADMIN_PASSWORD=

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# Username is you gmail ex: poopyhead@gmail.com
MAIL_USERNAME=
# Get a password for your mail at https://myaccount.google.com/apppasswords
MAIL_PASSWORD=

# ── Frontend (web/.env) ───────────────────────────────────────────────────────
# Canonical source for all VITE_* variables. Mirror these into web/.env for local dev.
# Leave VITE_BACKEND_URL empty to use same-origin (prod nginx proxy),
# or set it to http://localhost:8080 for local dev against the Spring Boot server.
VITE_BACKEND_URL=http://localhost:8080
VITE_FACEBOOK_APP_ID=
VITE_GCP_PROJECT_ID=
# Password that gates organizer self-registration on the signup page.
# Must match the codes configured in SignupPage or the backend organizer-key system.
VITE_ORGANIZER_SIGNUP_PASSWORD=
